@page
@model ManageUserModel
@{
	ViewData["Title"] = "Manage User";
}
<link rel="stylesheet" href="~/css/GenericForm.css" />
<link rel="stylesheet" href="~/css/manage.css" />

<h2>Manage Users</h2>
<div id="UserList" class="manage">
	<div class="genericform">
		@if (Model.UserList.Count == 0)
		{
			<p>No users found.</p>
		}
		else
		{
			<table>
				<tr>
					<td>Email</td>
					<td>Name</td>
					<td>Phone Number</td>
					<td>Actions</td>
				</tr>
				@foreach (Models.User User in @Model.UserList)
				{
					<tr>
						<td>@User.Email</td>
						<td>@User.FirstName @User.LastName</td>
						<td>@User.PhoneNumber</td>
						<td class="actions-cell">
							<button type="button"
									data-email="@User.Email"
									data-first-name="@User.FirstName"
									data-last-name="@User.LastName"
									data-phone-number="@User.PhoneNumber"
									data-address="@User.Address"
									data-city="@User.City"
									data-province="@User.Province"
									data-postal-code="@User.PostalCode"
									data-role="@User.Role"
									onclick="populateEditForm(this)">
								Edit
							</button>
							<form method="post" style="display:inline;">
								<input type="hidden" name="WarningEmail" value="@User.Email" />
								<button type="submit" asp-page-handler="ViewWarnings">View Warnings</button>
							</form>
							<form method="post" id="DeleteUserForm">
								<input type="hidden" name="EmailDelete" asp-for="EmailDelete" value="@User.Email" />
								<input type="submit" value="Delete" onclick="return confirm('Are you sure you want to delete this user?');" asp-page-handler="Delete" />
							</form>
						</td>
					</tr>
				}
			</table>
		}
	</div>

	<form id="ManageUserForm" method="post" class="genericform">
		<table>
			<tr>
				<td>Email: </td>
				<td><input type="text" id="EmailEdit" asp-for="EmailEdit" /></td>
			</tr>
			<tr>
				<td>First Name: </td>
				<td><input type="text" id="FirstNameEdit" asp-for="FirstNameEdit" /></td>
				<td>Last Name: </td>
				<td><input type="text" id="LastNameEdit" asp-for="LastNameEdit" /></td>
			</tr>
			<tr>
				<td>Phone Number: </td>
				<td><input type="number" id="PhoneNumberEdit" asp-for="PhoneNumberEdit" /></td>
			</tr>
			<tr>
				<td>Address: </td>
				<td><input type="text" id="AddressEdit" asp-for="AddressEdit" /></td>
				<td>City: </td>
				<td><input type="text" id="CityEdit" asp-for="CityEdit" /></td>
			</tr>
			<tr>
				<td>Province: </td>
				<td><input type="text" id="ProvinceEdit" asp-for="ProvinceEdit" /></td>
				<td>Postal Code: </td>
				<td><input type="text" id="PostalCodeEdit" asp-for="PostalCodeEdit" /></td>
			</tr>
			<tr>
				<td>Role: </td>
				<td>
					<select id="RoleEdit" asp-for="RoleEdit">
						<option value="">Select a Role</option>
						@foreach (SelectListItem role in Model.RolesList)
						{
							<option value="@role.Value">@role.Text</option>
						}
					</select>
				</td>
			</tr>
			<tr>
				<td><input type="submit" value="Submit" asp-page-handler="EditForm" /></td>
			</tr>
		</table>
	</form>
</div>



<div id="WarningList" style="display:none;" class="manage">
	@if (Model.ShowWarningList)
	{
		<div class="genericform">
			<h3>Warnings for @Model.WarningEmail</h3>
			@if (Model.WarningList.Count == 0)
			{
				<p>No warnings found for this user.</p>
			}
			else
			{
				<table>
					<tr>
						<td>Warning</td>
						<td>Start Date</td>
						<td>End Date</td>
					</tr>
					@foreach (Models.Warning warning in Model.WarningList)
					{
						<tr>
							<td>@warning.Message</td>
							<td>@warning.StartDate</td>
							<td>@warning.EndDate</td>
						</tr>
					}
				</table>
			}
		</div>
	}

	<form id="AddWarningForm" method="post" class="genericform" >
		<table>
			<input type="hidden" asp-for="WarningEmail" />
			<tr>
				<td>Warning Reason: </td>
				<td><input type="text" asp-for="WarningReason" /></td>
			</tr>
			<tr>
				<td>Warning End Date: </td>
				<td><input type="date" asp-for="WarningEndDate" /></td>
			</tr>
			<tr>
				<td><input type="submit" value="Add Warning" asp-page-handler="AddWarning" /></td>
				<td><button type="button" onclick="showManageUserForm()">Cancel</button></td>
			</tr>
		</table>
	</form>
</div>

<script>
	function showManageUserForm() {
		document.getElementById("UserList").style.display = "flex";
		document.getElementById("WarningList").style.display = "none";
	}

	function showAddWarningForm() {
		document.getElementById("UserList").style.display = "none";
		document.getElementById("WarningList").style.display = "flex";
	}

	function startAddWarning(button) {
		document.getElementById("WarningEmail").value = button.dataset.email;
		showAddWarningForm();
	}

	function populateEditForm(button) {
		const data = button.dataset;

		document.getElementById("EmailEdit").value = data.email;
		document.getElementById("FirstNameEdit").value = data.firstName;
		document.getElementById("LastNameEdit").value = data.lastName;
		document.getElementById("PhoneNumberEdit").value = data.phoneNumber;
		document.getElementById("AddressEdit").value = data.address;
		document.getElementById("CityEdit").value = data.city;
		document.getElementById("ProvinceEdit").value = data.province;
		document.getElementById("PostalCodeEdit").value = data.postalCode;
		document.getElementById("RoleEdit").value = data.role;
	}

	document.addEventListener("DOMContentLoaded", function() {
		@if (Model.ShowWarningList)
		{
			<text>showAddWarningForm();</text>
		}
		else
		{
			<text>showManageUserForm();</text>
		}
	});
</script>
